{
  "manifest_version": 3,
  "name": "StudentTracker Quick Logger",
  "version": "1.0.0",
  "description": "Auto-log applications from job portals (LinkedIn, Naukri, etc.) directly into StudentTracker.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Log Application"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"]
    }
  ]
}
